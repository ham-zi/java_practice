	public void declareVariable() {
		int price;
		

//data type(자료형)| Variable(변수식별자, 변수명)	
		
		// 초기화 (Initialization)
		// 변수는 자신이 선언된 {Scope}에서만 사용할 수 있음. 지역변수
		
		
		// 식별자 (Identifier)
		/*
		클래스명, 메소드명, 변수명, 등 개발자가 만들어서 이용하는 고유의 이름
		식별자를 만들 때 꼭 지켜야하는 규칙
		1. kweyWord(예약어)는 식별자로 사용할 수 없음
		2. 특수문자 '$','_' 만 사용 가능
		3. 공백 포함할 수 없음
		4. 대, 소문자를 구분하고 길이 제한 없음
		5. 숫자가 앞에 오는건 불가능 
		
		----------------------------------------------------
		암묵적인 약속
		1.클래스 / 인터페이스 명명 규칙
		
		- 첫 글짜는 대문자로 표기
		- 연결된 단어가 바뀔 때도 첫글짜 대문자로 표기
		- 명사, 형용사를 서술적으로 연결해서 사용
		
		
		
		
		2.변수 명명 규칙 (camelCase)
		- 명사적 의미를 갖게 만들어 줌
		- 첫글자를 소문자로 표기, 연결된 단어들의 첫글자를 대문자로 표기
		
		 -> phoneNumber
		 
		 3. 메소드 명명 규칙
		 
		 - 동사적 의미를 갖게 만들어줌
		 - 첫 첫글자를 소문자로 표기, 연결된 단어들의 첫글자를 대문자로 표기
		 - 메소드에는 _를 사용하지 않음

		
		4. 상수 명명 규칙
		
		- 모든 문자를 대문자로 표기
		- 단어 사이를 _ 사용한다.
		
		LOGIN_OK
		*
		*/
		
		//변수에 값을 대입하고 출력
		/*
		
		기본자료형 byte short char int long boolean float double
		정수형 byte short int long 
		- long 사용할 때는 대입할 숫자뒤에 L
		실수형 float double
		문자형 char
		불린형 boolean                   


		4. 문자열 : 참조자료형
		*/

		boolean isTrue = true;
		System.out.println(isTrue);
		// 지역변수(local variable)은 초기화하지 않으면 사용할 수 없음.
		
		String str = "문자열";
		byte byteNumber = 'A';
		short shortNumber = byteNumber;
		int intNumber = 1123123;
		long longNumber = 1234123L;
		char character = 'A';
		boolean isFalse = false;
		float floatNumber = 3.14F;
		double doubleNumber = 3.14;
		
		System.out.println(128*128);
		System.out.println(2*2*2*2*2*2*2*2);
		System.out.println(str);
		System.out.println(isTrue);
		System.out.println(byteNumber);
		System.out.println(shortNumber);
		System.out.println(intNumber);
		System.out.println(longNumber);
		System.out.println(character);
		System.out.println(isFalse);
		System.out.println(floatNumber);
		System.out.println(doubleNumber);
	
		// 1byte = 8bit
		
		// 단일문자에는 반드시 단일인용문구를 적는다. 'A'
		
		
		
		
		
		
	}
}
